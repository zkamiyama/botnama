{
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-write --allow-run --allow-env=READABLE_STREAM src/server.ts",
    "setup": "deno run --allow-net --allow-read --allow-write --allow-run=git,tar scripts/setup.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "plugin:mcv:build": "dotnet build plugins/mcv-botnama/MCV.Botnama.Plugin.csproj -c Release"
  },
  "imports": {
    "hono": "npm:hono@^4.4.10",
    "@std/path": "jsr:@std/path@^1.0.6",
    "@std/fs": "jsr:@std/fs@^1.0.6",
    "@std/toml": "jsr:@std/toml@^1.0.0",
    "jszip": "npm:jszip@^3.10.1",
    "@std/media-types": "jsr:@std/media-types@^1.0.3"
  },
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.ns"
    ],
    "strict": true,
    "noImplicitAny": true,
    "useUnknownInCatchVariables": false
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2
  },
  "lint": {
    "exclude": [
      "bin"
    ]
  }
}
